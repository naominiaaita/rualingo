<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical">

    <TextView
        android:id="@+id/vocabTopicHeader"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="16dp"
        android:layout_marginTop="20dp"
        android:layout_marginBottom="4dp"
        android:padding="8dp"
        android:background="@color/duo_gold"
        android:textColor="@color/duo_black"
        android:textSize="14sp"
        android:textStyle="bold"
        android:visibility="gone" />

    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="16dp"
        android:layout_marginVertical="8dp"
        app:cardCornerRadius="12dp"
        app:cardElevation="0dp"
        app:strokeColor="#E5E5E5"
        app:strokeWidth="2dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:id="@+id/vocabPrompt"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#3C3C3C"
            android:textSize="20sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/vocabPhonetic"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/duo_blue"
            android:textSize="14sp"
            android:textStyle="italic" />

        <TextView
            android:id="@+id/vocabAnswer"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:textColor="@color/duo_text_gray"
            android:textSize="16sp" />

        <View
            android:layout_width="40dp"
            android:layout_height="2dp"
            android:background="#E5E5E5"
            android:layout_marginVertical="8dp" />

        <TextView
            android:id="@+id/vocabExample"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#4B4B4B"
            android:textSize="14sp"
            android:textStyle="italic" />

        <TextView
            android:id="@+id/vocabTarget"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:textColor="@color/duo_gray"
            android:textSize="12sp"
            android:textAllCaps="true" />

        <TextView
            android:id="@+id/vocabTopic"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:textColor="@color/duo_blue"
            android:textSize="11sp"
            android:textStyle="bold" />
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
</LinearLayout>