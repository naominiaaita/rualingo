<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white"
    android:fitsSystemWindows="true"
    android:padding="16dp">

    <!-- Progress Bar -->
    <com.google.android.material.progressindicator.LinearProgressIndicator
        android:id="@+id/progressBar"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:layout_marginHorizontal="16dp"
        app:indicatorColor="@color/duo_blue"
        app:trackColor="#E5E5E5"
        app:trackCornerRadius="20dp"
        app:trackThickness="16dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        android:progress="30" />

    <ImageButton
        android:id="@+id/closeButton"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:src="@drawable/ic_close"
        app:tint="@color/duo_gray"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/progressBar"
        android:layout_marginTop="8dp" />

    <!-- Question Prompt -->
    <TextView
        android:id="@+id/questionPrompt"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:layout_marginHorizontal="16dp"
        android:text="Translate this sentence"
        android:textColor="#3C3C3C"
        android:textSize="22sp"
        android:textStyle="bold"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/closeButton" />

    <!-- Character & Bubble (Duolingo Style) -->
    <LinearLayout
        android:id="@+id/characterSection"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginTop="24dp"
        android:paddingHorizontal="16dp"
        app:layout_constraintTop_toBottomOf="@id/questionPrompt">

        <ImageView
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:src="@drawable/rualingo_logo" />

        <com.google.android.material.card.MaterialCardView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="16dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="0dp"
            app:strokeWidth="2dp"
            app:strokeColor="#E5E5E5">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:id="@+id/questionText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="..."
                    android:textColor="#3C3C3C"
                    android:textSize="18sp" />

                <TextView
                    android:id="@+id/hintText"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="Hint goes here"
                    android:textColor="#777777"
                    android:textSize="14sp"
                    android:textStyle="italic"
                    android:visibility="gone" />
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>
    </LinearLayout>

    <!-- Flashcard Card View (Specific for Vocabulary Introductions) -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/flashcardView"
        android:layout_width="match_parent"
        android:layout_height="300dp"
        android:layout_margin="32dp"
        android:visibility="gone"
        app:cardCornerRadius="24dp"
        app:cardElevation="4dp"
        app:strokeWidth="4dp"
        app:strokeColor="@color/duo_blue"
        app:layout_constraintBottom_toTopOf="@id/bottomSection"
        app:layout_constraintTop_toBottomOf="@id/questionPrompt">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:orientation="vertical"
            android:padding="24dp">

            <TextView
                android:id="@+id/flashcardWord"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Halo"
                android:textColor="@color/duo_black"
                android:textSize="40sp"
                android:textStyle="bold" />

            <View
                android:layout_width="60dp"
                android:layout_height="4dp"
                android:background="@color/duo_blue"
                android:layout_marginVertical="16dp" />

            <TextView
                android:id="@+id/flashcardTranslation"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Hi"
                android:textColor="@color/duo_text_gray"
                android:textSize="28sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:text="New Word Unlocked!"
                android:textColor="@color/duo_blue"
                android:textStyle="bold"
                android:textAllCaps="true" />
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <!-- Options Container -->
    <LinearLayout
        android:id="@+id/optionsContainer"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="32dp"
        android:layout_marginBottom="16dp"
        android:layout_marginHorizontal="16dp"
        android:orientation="vertical"
        app:layout_constraintBottom_toTopOf="@id/bottomSection"
        app:layout_constraintTop_toBottomOf="@id/characterSection">
        <!-- Options will be added dynamically -->
    </LinearLayout>

    <!-- Grammar/Story Content (Scrollable Text) -->
    <ScrollView
        android:id="@+id/textContentView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="24dp"
        android:layout_marginHorizontal="16dp"
        android:visibility="gone"
        app:layout_constraintBottom_toTopOf="@id/bottomSection"
        app:layout_constraintTop_toBottomOf="@id/questionPrompt">
        <TextView
            android:id="@+id/textContentText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="18sp"
            android:textColor="#4B4B4B"
            android:lineSpacingMultiplier="1.4"
            android:padding="8dp"/>
    </ScrollView>

    <!-- Matching Grid -->
    <androidx.gridlayout.widget.GridLayout
        android:id="@+id/matchingGrid"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="24dp"
        android:layout_marginHorizontal="16dp"
        android:visibility="gone"
        app:columnCount="2"
        app:alignmentMode="alignMargins"
        app:layout_constraintBottom_toTopOf="@id/bottomSection"
        app:layout_constraintTop_toBottomOf="@id/questionPrompt">
        <!-- Buttons added dynamically -->
    </androidx.gridlayout.widget.GridLayout>

    <!-- Speaking Icon -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/micButton"
        style="@style/Widget.MaterialComponents.Button.OutlinedButton"
        android:layout_width="120dp"
        android:layout_height="120dp"
        android:visibility="gone"
        app:icon="@android:drawable/ic_btn_speak_now"
        app:iconSize="64dp"
        app:iconGravity="textStart"
        app:iconPadding="0dp"
        app:cornerRadius="60dp"
        app:strokeWidth="4dp"
        app:layout_constraintBottom_toTopOf="@id/bottomSection"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/characterSection" />

    <!-- Bottom Section for Check/Continue -->
    <LinearLayout
        android:id="@+id/bottomSection"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingBottom="32dp"
        android:paddingHorizontal="32dp"
        app:layout_constraintBottom_toBottomOf="parent">

        <View
            android:layout_width="match_parent"
            android:layout_height="2dp"
            android:background="#E5E5E5"
            android:layout_marginBottom="24dp"
            android:layout_marginHorizontal="-16dp"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/checkButton"
            style="@style/DuolingoButton"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:text="CHECK"
            android:enabled="false" />
    </LinearLayout>

    <!-- Feedback Overlay (Hidden by default) -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/feedbackOverlay"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="32dp"
        android:visibility="gone"
        android:background="#D7FFB8"
        app:layout_constraintBottom_toBottomOf="parent">

        <TextView
            android:id="@+id/feedbackTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="GREAT JOB!"
            android:textColor="#58A700"
            android:textSize="22sp"
            android:textStyle="bold"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <TextView
            android:id="@+id/correctAnswerText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="Correct answer"
            android:textColor="#58A700"
            android:visibility="gone"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/feedbackTitle" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/continueButton"
            style="@style/DuolingoButton"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:layout_marginTop="24dp"
            android:text="CONTINUE"
            app:layout_constraintTop_toBottomOf="@id/correctAnswerText" />

    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.constraintlayout.widget.ConstraintLayout>